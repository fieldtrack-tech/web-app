# FieldTrack Frontend — Environment Variables

# Required: Backend API base URL (absolute URL or /api/proxy for proxy mode)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Proxy mode — set NEXT_PUBLIC_API_BASE_URL=/api/proxy and fill this in.
# Next.js will rewrite /api/proxy/* → API_DESTINATION_URL/* server-side (avoids CORS).
# API_DESTINATION_URL=https://api.fieldtrack.app
